{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "AI Agent 운영 모니터링 대시보드 — agent_* 메트릭 기반",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "요청 수 (agent_request_total)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(agent_request_total)",
          "legendFormat": "전체 요청 수",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "성공 수 (agent_success_total)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(agent_success_total)",
          "legendFormat": "성공 수",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "오류 수 (agent_error_total)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(agent_error_total)",
          "legendFormat": "오류 수",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "서비스 상태 (agent_service_status)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "agent_service_status",
          "legendFormat": "1=정상 / 0=비정상",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "비정상",
                  "color": "red"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "text": "정상",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "평균 응답시간 (agent_response_seconds)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(agent_response_seconds_sum[1m])) / sum by (mode) (rate(agent_response_seconds_count[1m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "p95 응답시간 (mode별)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "description": "최근 5분 동안 요청의 95%가 몇 초 안에 처리되었는지, mode별로 확인",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, mode) (rate(agent_response_seconds_bucket[5m])))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "오류율 % (mode별)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "100 * sum by (mode) (rate(agent_error_total[5m])) / sum by (mode) (rate(agent_request_total[5m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "품질평가 PASS율 (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "100 * sum(quality_eval_pass_total) / (sum(quality_eval_pass_total) + sum(quality_eval_fail_total))",
          "legendFormat": "PASS율(%)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "모드별 요청 수 추이 (rule / api / fault-lab)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "description": "mode별로 선이 나뉘어 표시됨 — 트래픽 종류가 다양할수록 선도 다양해짐",
      "targets": [
        {
          "expr": "sum by (mode) (rate(agent_request_total[1m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "fault-lab 성공/오류 비율 추이",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "description": "fault-lab 시나리오 중 성공(normal/delay) vs 오류(error500/timeout) 비율",
      "targets": [
        {
          "expr": "sum by (status) (rate(agent_request_total{mode=\"fault-lab\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1s",
  "schemaVersion": 38,
  "tags": [
    "ai-agent",
    "quality",
    "monitoring"
  ],
  "title": "AI Agent 운영 모니터링",
  "uid": "ai-agent-quality-v2",
  "version": 4
}